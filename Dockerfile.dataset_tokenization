# syntax=docker/dockerfile:1

FROM ghcr.io/astral-sh/uv:python3.12-bookworm

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

COPY pyproject.toml uv.lock ./
COPY src ./src
COPY config ./config

RUN uv sync --group dataset_tokenization --no-dev --frozen

ENTRYPOINT ["/app/.venv/bin/python", "-m", "training_signal_processing.main"]
CMD ["dataset-tokenization-validate", "--help"]
